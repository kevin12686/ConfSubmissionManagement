# Copy this file to one file per conference, for example:
#   cp .env.example .env.conference-a
#
# Then start with:
#   docker compose --env-file .env.conference-a -p sms-conf-a up -d --build

# Host port for this conference instance.
SMS_PORT=8000

# Bind to 127.0.0.1 for local-only access. Use 0.0.0.0 only on a trusted machine
# if another computer on the network must reach the app.
SMS_BIND_HOST=127.0.0.1

# Local folder that holds this conference's SQLite database and managed files.
SMS_DATA_DIR=./runtime/conference-a

# Keep this distinct per machine or deployment if the app is exposed beyond localhost.
SMS_SECRET_KEY=change-me-for-this-local-docker-instance

# Add the machine's LAN hostname or IP here if SMS_BIND_HOST=0.0.0.0.
SMS_ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# This Docker setup is intended for local/operator use with Django's development
# static/media serving enabled.
SMS_DEBUG=1
